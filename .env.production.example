# ============================================================
#  Template environment PRODUKSI (di EC2). Salin jadi ".env"
#  di samping docker-compose.yml, lalu isi nilainya.
#      cp .env.production.example .env
#  JANGAN commit file .env asli ke git.
# ============================================================

# Username Docker Hub (untuk nama image yang di-pull)
DOCKERHUB_USERNAME=ganti-username-dockerhub

# Password akun aplikasi MariaDB "uas-zayaksara" (satu-satunya akun yang dipakai)
# Isi nilai asli HANYA di file .env pada EC2 (jangan di template publik ini).
DB_PASSWORD=ganti-dengan-password-db

# Rahasia sesi Auth.js. Generate: npx auth secret
AUTH_SECRET=ganti-dengan-secret-acak-panjang

# URL publik aplikasi DINAMIS = http://<IP-PUBLIK-EC2>:8080
NEXTAUTH_URL=http://IP-PUBLIK-EC2:8080
